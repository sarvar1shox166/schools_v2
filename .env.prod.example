# Prod uchun nusxa: cp .env.prod.example .env.prod
# Keyin: docker compose --env-file .env.prod up -d --build

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=chess_school
POSTGRES_USER=chess
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── JWT ───────────────────────────────────────────────────────────────────────
# Har birini alohida yarating:  openssl rand -hex 32
JWT_SECRET=CHANGE_ME_64_CHAR_HEX
JWT_REFRESH_SECRET=CHANGE_ME_64_CHAR_HEX_DIFFERENT

# ── Ixtiyoriy ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
