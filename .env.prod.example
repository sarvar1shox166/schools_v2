# Prod uchun nusxa: cp .env.prod.example .env.prod
# Keyin: docker compose --env-file .env.prod up -d --build

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=chess_school
POSTGRES_USER=chess
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── JWT ───────────────────────────────────────────────────────────────────────
# Har birini alohida yarating:  openssl rand -hex 32
JWT_SECRET=CHANGE_ME_64_CHAR_HEX
JWT_REFRESH_SECRET=CHANGE_ME_64_CHAR_HEX_DIFFERENT

# ── AWS S3 (fayl saqlash — bo'sh qoldirsa local uploads/ ishlatiladi) ─────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-central-1
AWS_S3_BUCKET=chess-school-uploads
# CDN URL bo'lsa (CloudFront yoki boshqa): https://cdn.example.com
AWS_S3_CDN_URL=

# ── Ixtiyoriy ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
