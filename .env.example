# ── PostgreSQL (Docker Compose da ishlatiladi) ───────────────────────────────
POSTGRES_DB=chess_school
POSTGRES_USER=chess
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── API ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# Avtomatik quriladi docker-compose.yml da, shu qiymat dev uchun:
DATABASE_URL=postgres://chess:CHANGE_ME_STRONG_PASSWORD@db:5432/chess_school

# openssl rand -hex 32  →  64 belgili tasodifiy qiymat
JWT_SECRET=CHANGE_ME_64_CHAR_HEX
JWT_REFRESH_SECRET=CHANGE_ME_64_CHAR_HEX_DIFFERENT

# Ixtiyoriy
TELEGRAM_BOT_TOKEN=
